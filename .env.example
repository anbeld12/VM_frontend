# ========================================
# OBSERVATORIO V&M - FRONTEND CONFIGURATION
# ========================================
# Copia este archivo a .env y configura los valores según tu entorno.
# NOTA: Las variables que comienzan con VITE_ son expuestas al cliente.

# ========================================
# API CONFIGURATION
# ========================================
# URL base de la API del Backend
VITE_API_URL=http://localhost:8000

# ========================================
# THIRD-PARTY SERVICES
# ========================================
# Servicio de avatares (Ej: DiceBear)
VITE_AVATAR_SERVICE_URL=https://api.dicebear.com/7.x/avataaars/svg

# ========================================
# APP CONFIGURATION
# ========================================
# Nombre de la aplicación
VITE_APP_NAME=Observatorio V&M

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Entorno (development, staging, production)
VITE_ENVIRONMENT=development

# ========================================
# SEGURIDAD Y RECOMENDACIONES
# ========================================
# 1. NUNCA incluyas API keys privadas o secretos aquí.
# 2. El código compilado del frontend es PÚBLICO.
# 3. Cualquier variable VITE_* será visible en el navegador.
# 4. Los secretos deben manejarse ÚNICAMENTE en el backend.
