# VITE_* variables are exposed to the client (visible in compiled code)
# Only include non-sensitive configuration and public URLs here

# API Configuration
VITE_API_URL=http://localhost:8000

# Third-party Services
VITE_AVATAR_SERVICE_URL=https://api.dicebear.com/7.x/avataaars/svg

# App Configuration
VITE_APP_NAME=Observatorio V&M
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# IMPORTANT: Never add to VITE_ variables:
# - API keys or tokens
# - Database credentials
# - Private keys
# - Sensitive secrets
# 
# For backend communication, use environment-specific API_URL values
# Secrets should ONLY be handled server-side
